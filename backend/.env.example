PORT=3001
HOST=0.0.0.0

# Comma-separated frontend URLs (required in production)
# CLIENT_ORIGIN=https://your-app.vercel.app,https://www.yourdomain.com

# Redis — use Upstash "Redis URL" (rediss://...), not the REST URL
# REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

ROOM_TTL_SECONDS=14400
WALLET_TTL_SECONDS=2592000

# NODE_ENV=production
